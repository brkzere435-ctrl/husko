rules_version = '2';
// Canonique dans le dépôt : firestore.rules — déploiement : npm run firebase:deploy:rules
// À copier à la main dans la console Firebase → Firestore → Règles si besoin.
// ⚠️ Développement / test uniquement : tout le monde peut lire/écrire.
// Avant production : restreindre par auth (Firebase Auth) ou par domaine.

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
