{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "moduleSuffixes": [
      ".web",
      ".native",
      ""
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "IntelliJ IDEA 2026",
    ".expo",
    "android",
    "ios",
    "dist",
    "web-build"
  ]
}
