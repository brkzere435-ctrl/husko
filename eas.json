{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "local",
    "requireCommit": true
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "android": { "buildType": "apk" },
      "ios": { "simulator": true },
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "all",
        "EAS_BUILD_PROFILE": "development"
      }
    },
    "development-husko": {
      "extends": "apk-unified",
      "developmentClient": true,
      "channel": "development",
      "resourceClass": "large",
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "all",
        "EAS_BUILD_PROFILE": "development-husko"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" }
    },
    "apk": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "autoIncrement": "versionCode"
      },
      "env": { "EAS_BUILD_AUTOCOMMIT": "1" }
    },
    "apk-unified": {
      "distribution": "internal",
      "channel": "hub",
      "android": {
        "buildType": "apk",
        "autoIncrement": "versionCode"
      },
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "all",
        "EAS_BUILD_AUTOCOMMIT": "1"
      }
    },
    "apk-gerant": {
      "distribution": "internal",
      "channel": "gerant",
      "android": {
        "buildType": "apk",
        "autoIncrement": "versionCode"
      },
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "gerant",
        "EAS_BUILD_AUTOCOMMIT": "1"
      }
    },
    "apk-client": {
      "distribution": "internal",
      "channel": "client",
      "android": {
        "buildType": "apk",
        "autoIncrement": "versionCode"
      },
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "client",
        "EAS_BUILD_AUTOCOMMIT": "1"
      }
    },
    "apk-livreur": {
      "distribution": "internal",
      "channel": "livreur",
      "android": {
        "buildType": "apk",
        "autoIncrement": "versionCode"
      },
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "livreur",
        "EAS_BUILD_AUTOCOMMIT": "1"
      }
    },
    "apk-assistant": {
      "distribution": "internal",
      "channel": "assistant",
      "android": {
        "buildType": "apk",
        "autoIncrement": "versionCode"
      },
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "assistant",
        "EAS_BUILD_AUTOCOMMIT": "1"
      }
    },
    "ios-internal": {
      "distribution": "internal",
      "ios": { "simulator": true }
    },
    "ios-gerant": {
      "distribution": "internal",
      "ios": { "simulator": false },
      "env": { "EXPO_PUBLIC_APP_VARIANT": "gerant" }
    },
    "ios-client": {
      "distribution": "internal",
      "ios": { "simulator": false },
      "env": { "EXPO_PUBLIC_APP_VARIANT": "client" }
    },
    "ios-livreur": {
      "distribution": "internal",
      "ios": { "simulator": false },
      "env": { "EXPO_PUBLIC_APP_VARIANT": "livreur" }
    },
    "ios-assistant": {
      "distribution": "internal",
      "ios": { "simulator": false },
      "env": { "EXPO_PUBLIC_APP_VARIANT": "assistant" }
    },
    "mobile": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "autoIncrement": "versionCode"
      },
      "ios": { "simulator": false },
      "env": { "EAS_BUILD_AUTOCOMMIT": "1" }
    },
    "production": {
      "android": {
        "buildType": "app-bundle",
        "autoIncrement": "versionCode"
      },
      "ios": {},
      "env": { "EAS_BUILD_AUTOCOMMIT": "1" }
    }
  },
  "submit": {
    "production": {}
  }
}
