rules_version = '2';
// Déploiement : npm run firebase:deploy:rules (après firebase login + firebase use).
// Important: ce durcissement limite la surface exposée aux seules collections Husko utiles.
// Étape suivante production: auth Firebase + custom claims par rôle (client/livreur/gerant).

service cloud.firestore {
  match /databases/{database}/documents {
    match /orders/{orderId} {
      allow read, write: if true;

      match /tracking/{trackingId} {
        allow read, write: if true;
      }
    }

    match /meta/{docId} {
      allow read, write: if
        docId in ['driver', 'service', 'autonomousDemo'] ||
        docId.matches('^driver_order_.*$');
    }

    // Blocage explicite du reste tant que les règles auth par rôle ne sont pas en place.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
